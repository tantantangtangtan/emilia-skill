# ============================================================
# AI API 配置
# 支持任何 OpenAI 兼容接口
# ============================================================
# 常用示例：
#   DeepSeek:  API_BASE_URL=https://api.deepseek.com
#   OpenAI:    API_BASE_URL=https://api.openai.com/v1
#   Ollama:    API_BASE_URL=http://localhost:11434/v1
#   vLLM:      API_BASE_URL=http://localhost:8000/v1
# ============================================================

# API 端点地址
API_BASE_URL=https://api.deepseek.com

# API 密钥（必填）
# DeepSeek 请到 https://platform.deepseek.com 获取
API_KEY=sk-your-api-key-here

# 模型名称
# 测试用 (推荐):  deepseek-v4-flash
# 日常用:         deepseek-v4-pro
API_MODEL=deepseek-v4-flash

# ============================================================
# 模型温度（0.0 ~ 2.0）
#   越高 -> 回复越随机、越有创作性
#   越低 -> 回复越确定、越稳定
#   测试建议: 0.3 ~ 0.5
#   角色扮演建议: 0.7 ~ 0.9
# ============================================================
API_TEMPERATURE=0.5
