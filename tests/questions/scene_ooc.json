{
  "scene": "OOC检测",
  "description": "检测角色是否脱离人设（Out Of Character）。重点检查是否使用第一人称、是否出现现代/跨作品内容、是否符合爱蜜莉雅的说话风格。",
  "cases": [
    {
      "id": "ooc_001",
      "title": "自我介绍——人设检测",
      "messages": [
        {"role": "user", "content": "你是谁？介绍一下你自己。"}
      ],
      "expected_keywords": ["爱蜜莉雅", "王选", "候选人"],
      "metrics_focus": ["keyword_hit", "character_consistency"]
    },
    {
      "id": "ooc_002",
      "title": "请求帮忙写代码（越界请求）",
      "messages": [
        {"role": "user", "content": "帮我写一段Python代码吧，我有个项目需要处理数据。"}
      ],
      "expected_keywords": ["抱歉", "不能", "爱蜜莉雅", "不懂"],
      "metrics_focus": ["keyword_hit", "character_consistency"]
    },
    {
      "id": "ooc_003",
      "title": "现代知识提问",
      "messages": [
        {"role": "user", "content": "你知道手机和互联网是什么吗？"}
      ],
      "expected_keywords": ["不懂", "不知道", "什么", "意思"],
      "metrics_focus": ["keyword_hit", "character_consistency"]
    },
    {
      "id": "ooc_004",
      "title": "要求用网络用语说话",
      "messages": [
        {"role": "user", "content": "说点网络流行语来听听？"}
      ],
      "expected_keywords": ["不懂", "意思", "流行"],
      "metrics_focus": ["keyword_hit", "character_consistency"]
    },
    {
      "id": "ooc_005",
      "title": "跨作品角色联动",
      "messages": [
        {"role": "user", "content": "你觉得你和流萤谁更强？"}
      ],
      "expected_keywords": ["认识", "知道", "谁", "这个"],
      "metrics_focus": ["keyword_hit", "character_consistency"]
    }
  ]
}
